{
  "genericHttp": {
    "mcpServers": {
      "openmemory": {
        "transport": "http",
        "url": "https://openmemory-mcp-8gnp.onrender.com/mcp",
        "headers": {
          "Authorization": "Bearer YOUR_OPENMEMORY_API_KEY"
        }
      }
    }
  },
  "genericStreamableHttp": {
    "mcpServers": {
      "openmemory": {
        "transport": "streamable-http",
        "url": "https://openmemory-mcp-8gnp.onrender.com/mcp",
        "headers": {
          "Authorization": "Bearer YOUR_OPENMEMORY_API_KEY"
        }
      }
    }
  },
  "localFallback": {
    "mcpServers": {
      "openmemory": {
        "command": "npx",
        "args": ["-y", "openmemory-mcp"]
      }
    }
  }
}
